# Copy to .env and fill in values
# All variables are required unless marked optional

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...           # Postgres connection string (port 5432 for migrations)

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=                             # Strong random string (openssl rand -hex 32)

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESSKEYID=
AWS_SECRETACCESSKEY=
AWS_S3_BUCKETNAME=                      # S3 bucket for file uploads
AWS_S3_BUCKETNAMEFORIMAGES=             # S3 bucket for images (can be same as above)
AWS_CLOUDFRONT_URL=                     # CloudFront distribution URL (no trailing slash)

# ── Stripe (Connect must be enabled on the account) ──────────────────────────
STRIPE_SECRET_KEY=sk_test_...           # Test mode until launch. Currently a dummy — real keys needed for B1.
STRIPE_WEBHOOK_SECRET=whsec_...         # Webhook signing secret for /backend-api/payment/webhook

# ── Email (magic links + Countersignature notices) ───────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:5173 # Where magic links and Stripe onboarding redirects land

# ── Runtime ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
