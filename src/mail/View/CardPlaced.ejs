<!DOCTYPE html>
<html>
  <body style="margin:0;padding:0;background:#14120f;font-family:Georgia,'Times New Roman',serif;color:#e8e2d6;">
    <div style="max-width:520px;margin:0 auto;padding:48px 24px;">
      <p style="font-size:15px;line-height:1.6;color:#8a8478;margin:0 0 10px;">Hi <%= creatorName %>,</p>
      <h1 style="font-size:26px;line-height:1.2;font-weight:400;margin:0 0 18px;">A new card landed on <%= frameTitle %>.</h1>
      <p style="font-size:17px;line-height:1.6;margin:0 0 12px;"><%= displayName %> left a card.</p>
      <% if (amountCents) { %>
        <p style="font-size:15px;line-height:1.6;color:#cdbb91;margin:0 0 12px;">Amount: $<%= Math.round(amountCents / 100) %></p>
      <% } %>
      <% if (note) { %>
        <p style="font-size:16px;line-height:1.6;margin:0 0 26px;color:#d8d0bf;">"<%= note %>"</p>
      <% } %>
      <p style="margin:0 0 28px;">
        <a href="<%= cardUrl %>" style="display:inline-block;padding:14px 28px;background:#e8e2d6;color:#14120f;text-decoration:none;font-size:16px;letter-spacing:0.02em;">Open frame</a>
      </p>
      <p style="font-size:13px;line-height:1.6;color:#8a8478;margin:0;">You can hold any photo you do not want on the public frame.</p>
    </div>
  </body>
</html>
