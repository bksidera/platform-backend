<!DOCTYPE html>
<html>
  <body style="margin:0;padding:0;background:#14120f;font-family:Georgia,'Times New Roman',serif;color:#e8e2d6;">
    <div style="max-width:480px;margin:0 auto;padding:48px 24px;">
      <% if (kind === 'creator') { %>
        <p style="font-size:17px;line-height:1.6;margin:0 0 28px;">Use the link below to sign in. It expires in 15 minutes.</p>
        <p style="margin:0 0 28px;">
          <a href="<%= link %>" style="display:inline-block;padding:14px 28px;background:#e8e2d6;color:#14120f;text-decoration:none;font-size:16px;letter-spacing:0.02em;">Sign in</a>
        </p>
      <% } else { %>
        <p style="font-size:17px;line-height:1.6;margin:0 0 28px;">Your cards are kept under this address. Use the link below to claim them. It expires in 15 minutes.</p>
        <p style="margin:0 0 28px;">
          <a href="<%= link %>" style="display:inline-block;padding:14px 28px;background:#e8e2d6;color:#14120f;text-decoration:none;font-size:16px;letter-spacing:0.02em;">Claim your place</a>
        </p>
      <% } %>
      <p style="font-size:13px;line-height:1.6;color:#8a8478;margin:0;">If you didn't request this, you can ignore this email.</p>
    </div>
  </body>
</html>
