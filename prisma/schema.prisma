generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// PLATFORM data model.
// Living Frame is the active product model: a creator-owned image with visitor
// cards attached below it. Monument / Inscription remain only as deprecated
// scaffolding until the production cutover is complete.

enum ArchiveVisibility {
  aggregate_only
  show_opted_in
}

enum GiverStatus {
  guest
  claimed
}

enum MonumentStatus {
  active
  archived
}

enum FrameStatus {
  active
  archived
}

enum StreamType {
  moment
  stewardship_charge
}

enum StreamStatus {
  pending
  succeeded
  failed
}

enum ModerationStatus {
  pending
  approved
  held
}

enum CardPaymentStatus {
  none
  pending
  succeeded
  failed
}

enum Visibility {
  private
  public
}

enum StewardshipStatus {
  active
  lapsed
  canceled
}

model Creator {
  id                String            @id @default(uuid())
  name              String
  slug              String            @unique
  email             String            @unique
  bio               String?
  heroImageUrl      String?
  mediaLinks        Json? // [{ kind: 'spotify'|'bandcamp'|'youtube'|'link', url }]
  stripeAccountId   String?           @unique
  stripeOnboarded   Boolean           @default(false)
  archiveVisibility ArchiveVisibility @default(aggregate_only)
  createdAt         DateTime          @default(now())

  frames            Frame[]
  cards             Card[]
  monuments         Monument[]
  streams           Stream[]
  stewardships      Stewardship[]
  countersignatures Countersignature[]
}

model Giver {
  id        String      @id @default(uuid())
  name      String
  email     String      @unique
  status    GiverStatus @default(guest)
  createdAt DateTime    @default(now())

  streams      Stream[]
  cards        Card[]
  inscriptions Inscription[]
  stewardships Stewardship[]
}

model Frame {
  id        String      @id @default(uuid())
  creatorId String
  imageUrl  String
  title     String
  context   String?
  slug      String      @unique
  status    FrameStatus @default(active)
  createdAt DateTime    @default(now())

  creator Creator @relation(fields: [creatorId], references: [id])
  cards   Card[]

  @@index([creatorId])
}

model Card {
  id                    String             @id @default(uuid())
  frameId               String
  creatorId             String
  giverId               String
  streamId              String?            @unique
  displayName           String
  email                 String
  note                  String?            @db.VarChar(240)
  photoUrl              String?
  photoModerationStatus ModerationStatus?
  amountCents           Int?
  currency              String             @default("usd")
  paymentStatus         CardPaymentStatus  @default(none)
  visibility            Visibility         @default(public)
  hiddenByCreator       Boolean            @default(false)
  reportedAt            DateTime?
  reportReason          String?            @db.VarChar(240)
  createdAt             DateTime           @default(now())

  frame   Frame   @relation(fields: [frameId], references: [id])
  creator Creator @relation(fields: [creatorId], references: [id])
  giver   Giver   @relation(fields: [giverId], references: [id])
  stream  Stream? @relation(fields: [streamId], references: [id])

  @@index([frameId, createdAt])
  @@index([creatorId, createdAt])
  @@index([giverId])
}

model Monument {
  id           String         @id @default(uuid())
  creatorId    String
  imageUrl     String
  title        String
  venue        String
  eventDate    DateTime
  qrSourceSlug String         @unique
  status       MonumentStatus @default(active)
  createdAt    DateTime       @default(now())

  creator      Creator       @relation(fields: [creatorId], references: [id])
  streams      Stream[]
  inscriptions Inscription[]

  @@index([creatorId])
}

// Append-only. The Ledger's source of truth.
model Stream {
  id                    String       @id @default(uuid())
  giverId               String
  creatorId             String
  monumentId            String? // nullable — Streams can occur off-Monument from the Archive
  type                  StreamType
  amountCents           Int
  currency              String       @default("usd")
  status                StreamStatus @default(pending)
  stripePaymentIntentId String?      @unique
  venueStamp            String? // "venue · date", carried from the QR source param
  occurredAt            DateTime     @default(now())

  giver            Giver             @relation(fields: [giverId], references: [id])
  creator          Creator           @relation(fields: [creatorId], references: [id])
  monument         Monument?         @relation(fields: [monumentId], references: [id])
  card             Card?
  inscription      Inscription?
  countersignature Countersignature?

  @@index([creatorId, occurredAt])
  @@index([giverId])
}

// Immutable after placement except visibility / hiddenByCreator.
model Inscription {
  id                    String            @id @default(uuid())
  streamId              String            @unique // THE PAYMENT GATE — required, one pin per Stream
  giverId               String
  monumentId            String
  x                     Float // normalized 0–1 against image dimensions
  y                     Float // normalized 0–1
  glyph                 String
  observationText       String?           @db.VarChar(240)
  photoUrl              String?
  photoModerationStatus ModerationStatus?
  visibility            Visibility        @default(private) // giver's per-artist key
  hiddenByCreator       Boolean           @default(false) // creator's per-pin key
  createdAt             DateTime          @default(now())

  stream           Stream            @relation(fields: [streamId], references: [id])
  giver            Giver             @relation(fields: [giverId], references: [id])
  monument         Monument          @relation(fields: [monumentId], references: [id])
  countersignature Countersignature?

  @@index([monumentId])
  @@index([giverId])
}

model Stewardship {
  id                   String            @id @default(uuid())
  giverId              String
  creatorId            String
  amountCents          Int
  status               StewardshipStatus @default(active)
  stripeSubscriptionId String            @unique
  visibility           Visibility        @default(private) // giver's per-artist key
  startedAt            DateTime          @default(now())
  endedAt              DateTime?

  giver   Giver   @relation(fields: [giverId], references: [id])
  creator Creator @relation(fields: [creatorId], references: [id])

  @@index([creatorId, status])
  @@index([giverId])
}

model Countersignature {
  id            String   @id @default(uuid())
  creatorId     String
  inscriptionId String?  @unique // set for on-Monument Streams
  streamId      String?  @unique // set for off-Monument Streams
  createdAt     DateTime @default(now())

  creator     Creator      @relation(fields: [creatorId], references: [id])
  inscription Inscription? @relation(fields: [inscriptionId], references: [id])
  stream      Stream?      @relation(fields: [streamId], references: [id])
}

// One-time magic-link tokens for creator login and giver identity claiming.
model MagicLinkToken {
  id        String    @id @default(uuid())
  token     String    @unique
  email     String
  kind      String // 'creator' | 'giver'
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// Instrumentation (spec §9/§11). No third-party analytics.
model Event {
  id         String   @id @default(uuid())
  type       String // qr_scan | monument_view | checkout_start | checkout_complete | pin_placed | observation_attached | photo_attached | graduation_view | graduation_accept | countersign | claim
  sourceSlug String?
  creatorId  String?
  monumentId String?
  frameId    String?
  cardId     String?
  giverId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([monumentId])
  @@index([frameId])
  @@index([cardId])
}
